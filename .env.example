# ===========================================
# Supabase Database Configuration
# ===========================================
# Daftar gratis di: https://supabase.com
# Lihat panduan lengkap di bawah

# URL proyek Supabase (ditemukan di Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (ditemukan di Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ===========================================
# CARA SETUP SUPABASE (GRATIS)
# ===========================================
#
# 1. Buat akun gratis di https://supabase.com
#
# 2. Buat project baru:
#    - Klik "New Project"
#    - Pilih organization
#    - Nama project: "mbuzenkzetro"
#    - Database password: (buat password kuat)
#    - Region: Singapore (paling dekat dengan Indonesia)
#    - Klik "Create new project"
#
# 3. Buat tabel testimonials:
#    - Buka menu "SQL Editor" di sidebar
#    - Klik "New query"
#    - Copy paste SQL di bawah ini:
#
# CREATE TABLE testimonials (
#   id BIGSERIAL PRIMARY KEY,
#   name VARCHAR(100) NOT NULL,
#   role VARCHAR(100) NOT NULL,
#   location VARCHAR(100) NOT NULL,
#   content TEXT NOT NULL,
#   rating INTEGER NOT NULL CHECK (rating >= 1 AND rating <= 5),
#   date DATE NOT NULL DEFAULT CURRENT_DATE,
#   project VARCHAR(100),
#   created_at TIMESTAMP WITH TIME ZONE DEFAULT NOW()
# );
#
# -- Enable RLS (Row Level Security)
# ALTER TABLE testimonials ENABLE ROW LEVEL SECURITY;
#
# -- Allow anyone to read testimonials
# CREATE POLICY "Allow anonymous read access" ON testimonials
#   FOR SELECT
#   USING (true);
#
# -- Allow anyone to insert testimonials
# CREATE POLICY "Allow anonymous insert" ON testimonials
#   FOR INSERT
#   WITH CHECK (true);
#
#    - Klik "Run" untuk menjalankan
#
# 4. Ambil kredensial:
#    - Buka Settings > API
#    - Copy "Project URL" -> paste ke NEXT_PUBLIC_SUPABASE_URL
#    - Copy "anon public" key -> paste ke NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# 5. Deploy ulang di Vercel:
#    - Masukkan environment variables di Vercel dashboard
#    - Redeploy project
#
# ===========================================
