# =============================================
# ENVIRONMENT VARIABLES - MBUZENK ZETRO
# =============================================
# Copy file ini ke .env.local dan isi nilai yang sesuai

# ---------------------------------------------
# UPSTASH REDIS (Untuk penyimpanan testimoni)
# ---------------------------------------------
# Dapatkan dari: https://upstash.com/
# Digunakan untuk menyimpan testimoni pelanggan secara permanen

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------
# GOOGLE VERIFICATION (Opsional)
# ---------------------------------------------
# Untuk Google Search Console verification

NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ---------------------------------------------
# ANALYTICS (Opsional)
# ---------------------------------------------
# Google Analytics 4 Measurement ID

NEXT_PUBLIC_GA_ID=

# ---------------------------------------------
# SITE CONFIGURATION
# ---------------------------------------------
# URL production website

NEXT_PUBLIC_SITE_URL=https://www.mbuzenkzetro.com
